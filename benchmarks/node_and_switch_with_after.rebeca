reactiveclass Node(100) {
    knownrebecs{
        Switch switch0;
        Switch switch1;
    }

    @priority(1)
    msgsrv runme(int in0){
        //do task
    }
}

reactiveclass Switch(100) {
    knownrebecs{
        Node node0;
    }

    Switch(){
        self.runme2(0);
    }

    @priority(1)
    msgsrv runme2(int in1){
        node0.runme(in1) after(1);
    }
}

main {
    Node node0(sw0, sw1):();
    @priority(1) Switch sw0(node0):();
    @priority(2) Switch sw1(node0):();
}