reactiveclass Sender(100) {
    knownrebecs{
        Receiver receiver0;
    }

    Sender() {
        self.sendMessage(1);
    }

    @priority(1)
    msgsrv sendMessage(int data){
        receiver0.receiveMessage(data);
    }
}

reactiveclass Receiver(100) {
    @priority(1)
    msgsrv receiveMessage(int data){
        // Process data
    }
}

main {
    Sender sender0(receiver0):();
    Receiver receiver0():();
}