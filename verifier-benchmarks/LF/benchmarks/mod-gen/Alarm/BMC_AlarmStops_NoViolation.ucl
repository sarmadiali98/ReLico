    ( true
    && Alarm_c_out(s(i)) == 0
    && Alarm_c_out_is_present(t(i)) == false)
    ))
    && (true ==> (
    ( true
    && Alarm_c_out2(s(i)) == 0
    && Alarm_c_out2_is_present(t(i)) == false)
    ))
    && (true ==> (
    ( true
    && Alarm_c_stopResult(s(i)) == 0
    && Alarm_c_stopResult_is_present(t(i)) == false)
    ))
    && (true ==> (
    Alarm_c_turnOff_scheduled(d(i)) == false
    ))
    ))));
    /************
     * Property *
     ************/
    // The FOL property translated from user-defined MTL property:
    // G[0, 1500 msec](Alarm_chk_violation == 0)
    define p(i : step_t) : boolean =
        (((finite_forall (j0 : integer) in indices :: (j0 >= i && j0 <= END && !isNULL(j0) && (
        // Time Predicate
        (pi1(g(j0)) >= (pi1(g(i)) + 0)) && (pi1(g(j0)) <= (pi1(g(i)) + 1500000000))
        )) ==> (((Alarm_chk_violation(s(j0)) == 0))))));
    // BMC
    property bmc_AlarmStops_NoViolation : initial_condition() ==> p(0);
    control {
        v = bmc(0);
        check;
        print_results;
        v.print_cex_json;
    }
}
