    // Projection macros for scheduled payloads
    /*********************
     * Reactor Semantics *
     *********************/
    // Non-federated "happened-before"
    define hb(e1, e2 : event_t) : boolean
    = tag_earlier(e1._2, e2._2)
        || (tag_same(e1._2, e2._2) && ( false
        || (Minimal_ctr_reaction_1(e1._1) && Minimal_chk_reaction_1(e2._1))
