    ));
    // If Minimal_chk_xIn is not present, then its value resets to 0.
    axiom(finite_forall (i : integer) in indices :: (i > START && i <= END_TRACE && !isNULL(i)) ==> (
        (!Minimal_chk_xIn_is_present(t(i)) ==> (
            Minimal_chk_xIn(s(i)) == 0
        ))
