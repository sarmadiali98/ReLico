    /**********
     * Timers *
     **********/
    //// Axioms for Minimal.ctr.t
    // Minimal.ctr.t: an initial firing at (0, 0)
    axiom(
        ((pi1(g(END)) >= 0) ==> (
            finite_exists (j : integer) in indices :: (j > START && j <= END)
                && Minimal_ctr_t_is_present(t(j))
                && tag_same(g(j), {0, 0})
         ))
         && ((pi1(g(END)) < 0) ==> (
            finite_forall (i : integer) in indices :: (i > START && i <= END)
                ==> (!isNULL(i))
         ))
    );
    // Minimal.ctr.t: schedule subsequent firings every 10000000 ns
    axiom(
        finite_forall (i : integer) in indices :: (i >= START && i <= END) ==> (
            Minimal_ctr_t_is_present(t(i)) ==> (
                (
                    finite_exists (j : integer) in indices :: (j >= START && j > i)
                        && Minimal_ctr_t_is_present(t(j))
