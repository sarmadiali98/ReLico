    define d        (i : step_t) : sched_t      = elem(i)._5;
    define pl       (i : step_t) : payload_t    = elem(i)._6;
    define isNULL   (i : step_t) : boolean      = rxn(i) == {false, false};
    /**********************************
     * Reaction IDs & State Variables *
     *********************************/
    
    //////////////////////////
    // Application Specific
    // Reactions
    type rxn_t = {
        boolean,	// reaction_1 of Minimal.ctr(level: 0)
        boolean	// reaction_1 of Minimal.chk(level: 1, dominating: reaction_1 of Minimal.ctr)
    };
    // Reaction projection macros
    define Minimal_ctr_reaction_1(n : rxn_t) : boolean = n._1;
