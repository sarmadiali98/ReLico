target C;

reactor Source {
    output n:int;

    reaction(startup) -> n {=
        lf_set(n, 4);
    =}
}

reactor FactorialCore {
    input n:int;
    output resultOut:int;
    output done:int;

    logical action a(10 msec):int;

    reaction(n) -> a {=
        if (n->value == 4) {
            lf_schedule_int(a, 0, 24);
        } else {
            lf_schedule_int(a, 0, 0);
        }
    =}

    reaction(a) -> resultOut, done {=
        lf_set(resultOut, a->value);
        lf_set(done, 1);
    =}
}

reactor Checker {
    input resultIn:int;
    input doneIn:int;

    logical action decide(11 msec);

    state seenResult:int = 0;
    state gotDone:int = 0;
    state violation:int = 0;

    reaction(startup) -> decide {=
        lf_schedule(decide, 0);
    =}

    reaction(resultIn) {=
        self->seenResult = resultIn->value;
    =}

    reaction(doneIn) {=
        self->gotDone = 1;
    =}

    reaction(decide) {=
        if (self->gotDone == 0) {
            self->violation = 1;
        } else if (self->seenResult != 24) {
            self->violation = 1;
        }
    =}
}

reactor KeepAlive {
    timer t(100 msec, 100 msec);
    state phase:int = 0;

    reaction(t) {=
        if (self->phase == 0) {
            self->phase = 1;
        } else {
            self->phase = 0;
        }
    =}
}

@property(
    name="Factorial_NoViolation",
    tactic="bmc",
    spec="G[0, 12 msec](Factorial_chk_violation == 0)",
    expect=true
)
main reactor Factorial {
    src = new Source();
    f = new FactorialCore();
    chk = new Checker();
    ka = new KeepAlive();

    src.n -> f.n;
    f.resultOut -> chk.resultIn;
    f.done -> chk.doneIn;
}
