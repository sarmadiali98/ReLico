target C;

reactor Counter {
    state x:int = 0;
    state violation:int = 0;

    timer t(0, 10 msec);

    reaction(t) {=
        if (self->x == 0) {
            self->x = 1;
        } else {
            self->x = 0;
        }

        if (self->x < 0) {
            self->violation = 1;
        }
    =}
}

@property(
    name="Minimal_NoViolation",
    tactic="bmc",
    spec="G[0, 100 msec](Minimal_ctr_violation == 0)",
    expect=true
)
main reactor Minimal {
    ctr = new Counter();
}
